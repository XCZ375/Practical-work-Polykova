line = input("Ввод: ").split()        # Считываем строку и разбиваем её на список слов
unique_words = set(line)              # Преобразуем список в множеств
words_count = len(unique_words)       # Считаем количество уникальных слов
sorted_words = sorted(unique_words)   # Сортируем множество по алфавиту

print(f" Слова: {sorted_words}")      # Выводим отсортированный список уникальных слов
print(f"Количество: {words_count}")   # Выводим количество уникальных слов
