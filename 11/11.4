n = int(input("Введите число: "))
number = n
 
# последняя цифра числа
last_digit = number % 10
 
# начальные значения
count_3 = 0
count_last = 0
count_even = 0
sum_gt5 = 0
product_gt7 = 1
count_0_5 = 0
 
# перебираем цифры через while
while number > 0:
    digit = number % 10
 
    if digit == 3:
        count_3 += 1
 
    if digit == last_digit:
        count_last += 1
 
    if digit % 2 == 0:
        count_even += 1
 
    if digit > 5:
        sum_gt5 += digit
 
    if digit > 7:
        product_gt7 *= digit
 
    if digit == 0 or digit == 5:
        count_0_5 += 1
 
    number //= 10
 
print(count_3)
print(count_last)
print(count_even)
print(sum_gt5)
print(product_gt7)
print(count_0_5)
 
