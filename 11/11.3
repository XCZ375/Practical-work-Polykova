# Cчитываем пятые степени чисел
powers = [i ** 5 for i in range(151)]

# Перебор значений
for a in range(1, 151):
    for b in range(a, 151):
        for c in range(b, 151):
            for d in range(c, 151):

                # Сумма четырех пятых степеней
                sum_abcd = powers[a] + powers[b] + powers[c] + powers[d]

                # Проверяем, есть ли такое "e"
                for e in range(d, 151):
                    if powers[e] == sum_abcd:
                        print("Найдено решение:")
                        print(f"a={a}, b={b}, c={c}, d={d}, e={e}")
                        print("Сумма:", a + b + c + d + e)
                        break
