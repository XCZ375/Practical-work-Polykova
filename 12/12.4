marks = [5, 4, 3, 5, 2, 5, 4, 3, 5, 5]
 
count_5 = 0  # счётчик пятёрок
count_2 = 0  # счётчик двоек
 
# Перебираем каждую оценку в списке
for mark in marks:
    if mark == 5:
        count_5 += 1
    if mark == 2:
        count_2 += 1
 
print(f"Количество пятёрок: {count_5}")
print(f"Количество двоек: {count_2}")
