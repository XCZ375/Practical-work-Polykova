import random

# Генерируем вложенный список
nested_list = [
    [random.randint(-20, 50) for _ in range(5)]
    for _ in range(4)]

print("Вложенный список:")
for row in nested_list:
    print(f"  {row}")

# Список для хранения суммы каждой строки
row_sums = []

# Общая сумма всех элементов
total_sum = 0

# Перебираем строки по индексу 
for row_index in range(len(nested_list)):
    current_row_sum = sum(nested_list[row_index])
    row_sums.append(current_row_sum)
    total_sum += current_row_sum
    print(f"Сумма строки {row_index}: {current_row_sum}")

# Ищем строку с максимальной суммой
max_row_sum = max(row_sums)
max_row_index = row_sums.index(max_row_sum)

print(f"Общая сумма всех элементов: {total_sum}")
print(f"Строка с максимальной суммой: индекс {max_row_index}, "
      f"сумма = {max_row_sum}")
print(f"Содержимое строки: {nested_list[max_row_index]}")
