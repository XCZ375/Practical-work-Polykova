class Weapon:
    def __init__(self, name, damage):
        self.name = name
        self.damage = damage

class SilverSword(Weapon):
    def __init__(self):
        super().__init__("Серебряный меч", 30)

    def use(self, monster):
        print(f"Охотник взмахивает {self.name}!")
        monster.take_damage(self.damage)

class HolyWater(Weapon):
    def __init__(self):
        super().__init__("Святая вода", 20)

    def use(self, monster):
        print(f"Охотник окропляет монстра {self.name}!")
        monster.take_damage(self.damage)

class CrossbowBolt(Weapon):
    def __init__(self):
        super().__init__("Арбалет с болтом", 25)

    def use(self, monster):
        print(f"Охотник стреляет из {self.name}!")
        monster.take_damage(self.damage)

