# ЭТАП 4 ---

class Hunter:
    def __init__(self, name):
        self.__name = name
        self.__hp = 100
        self.__weapons = []

    def get_name(self):
        return self.__name

    def get_hp(self):
        return self.__hp

    def set_hp(self, value):
        self.__hp = max(value, 0)

    def is_alive(self):
        return self.__hp > 0

    def add_weapon(self, weapon):
        self.__weapons.append(weapon)

    def weapon_count(self):
        return len(self.__weapons)

    def show_inventory(self):
        print("Арсенал охотника:")
        for i, w in enumerate(self.__weapons):
            print(f"  {i}. {w.name} (урон: {w.damage})")

    def attack(self, weapon_index, monster):
        self.__weapons[weapon_index].use(monster)


    def show_status(self):
        print(f"[{self.__name}] HP: {self.__hp}")

# ЭТАП 5 ---

def run_game():
    hunter = Hunter("Ван Хельсинг")
    hunter.add_weapon(SilverSword())
    hunter.add_weapon(HolyWater())
    hunter.add_weapon(CrossbowBolt())

    hunter.show_inventory()

    monsters = [Zombie("Зомби"), Vampire("Дракула"), Ghost("Призрак"), Werewolf("Оборотень")]

    for monster in monsters:
        print()
        print("Новый враг:", monster.get_name())

        while monster.is_alive() and hunter.is_alive():
            hunter.attack(0, monster)          # бьём мечом
            if monster.is_alive():
                monster.attack_hunter(hunter)
            hunter.show_status()

        if not hunter.is_alive():
            break

    print()
    if hunter.is_alive():
        print("Победа! Охотник зачистил замок.")
    else:
        print("Поражение. Охотник погиб.")

run_game()
