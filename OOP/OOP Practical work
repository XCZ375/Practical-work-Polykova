# ЭТАП 2 ---


class Zombie(Monster):
    def __init__(self, name="Зомби"):
        super().__init__(name, 120, 10)

    def take_damage(self, damage):
        self.set_hp(self.get_hp() - damage)
        print(f"{self.get_name()} теряет конечность! Получено: {damage}. HP: {self.get_hp()}")

class Vampire(Monster):
    def __init__(self, name="Вампир"):
        super().__init__(name, 80, 15)
        self.__absorb = 5

    def take_damage(self, damage):
        actual = max(damage - self.__absorb, 0)
        self.set_hp(self.get_hp() - actual)
        print(f"{self.get_name()} поглощает {self.__absorb} урона! Получено: {actual}. HP: {self.get_hp()}")

class Ghost(Monster):
    def __init__(self, name="Призрак"):
        super().__init__(name, 60, 20)
        self.__dodge_chance = 0.3

    def take_damage(self, damage):
        if random.random() < self.__dodge_chance:
            print(f"{self.get_name()} уклоняется от удара! Урон не получен. HP: {self.get_hp()}")
        else:
            self.set_hp(self.get_hp() - damage)
            print(f"{self.get_name()} получает удар! Получено: {damage}. HP: {self.get_hp()}")

class Werewolf(Monster):
    def __init__(self, name="Оборотень"):
        super().__init__(name, 100, 25)
        self.__transformed = False

    def take_damage(self, damage):
        self.set_hp(self.get_hp() - damage)
        print(f"{self.get_name()} получает удар! Получено: {damage}. HP: {self.get_hp()}")
        if not self.__transformed and self.is_alive() and self.get_hp() < 50:
            self.__transformed = True
            print(f"{self.get_name()} трансформируется в чудовищную форму")

