def is_password_good(password):
    """
    Проверяет надёжность пароля по четырём критериям.

    Пароль считается надёжным, если:
        длина не менее 8 символов
        есть хотя бы одна заглавная буква
        есть хотя бы одна строчная буква
        есть хотя бы одна цифра

    Возвращает:
        bool: True если пароль надёжный, False в противном случае
    """
    # Условие 1: длина не менее 8 символов
    if len(password) < 8:
        return False

    # Условие 2: хотя бы одна заглавная буква
    if not any(ch.isupper() for ch in password):
        return False

    # Условие 3: хотя бы одна строчная буква
    if not any(ch.islower() for ch in password):
        return False

    # Условие 4: хотя бы одна цифра
    if not any(ch.isdigit() for ch in password):
        return False

    # Все условия выполнены — пароль надёжный
    return True


# Проверка работы функции
print(is_password_good('aabbCC11OP'))  # длина 10, есть A-Z, a-z, 0-9 → True
print(is_password_good('abC1pu'))      # длина 6 — слишком короткий → False
