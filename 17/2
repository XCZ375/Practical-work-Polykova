def is_prime(num):
    """
    Проверяет, является ли число простым.

    Аргумент:
        num (int): натуральное число

    Возвращает:
        bool: True если число простое, False в противном случае
    """

    if num < 2:
        return False

    # Проверяем делители от 2 до корня из num включительно.
    # Если num делится на какое-либо число в этом диапазоне оно составно

    for i in range(2, int(num ** 0.5) + 1):
        if num % i == 0:
            return False

    # Делителей не найдено — число простое
    return True


# Проверка работы функции
print(is_prime(1))  # 1 — не простое → False
print(is_prime(10))  # 10 = 2 * 5 — составное → False
print(is_prime(17))  # делителей нет → True
