def get_days(month):
    """
    Возвращает количество дней в месяце (невисокосный год).

    Аргумент:
        month (int): номер месяца от 1 до 12

    Возвращает:
        int: количество дней в данном месяце
    """
    # Месяцы с 31 днём: январь, март, май, июль, август, октябрь, декабрь
    days_31 = {1, 3, 5, 7, 8, 10, 12}

    # Месяцы с 30 днями: апрель, июнь, сентябрь, ноябрь
    days_30 = {4, 6, 9, 11}

    if month in days_31:
        return 31
    elif month in days_30:
        return 30
    else:
        # Единственный оставшийся месяц — февраль (месяц 2)
        return 28


# Проверка работы функции
print(get_days(1))  # Январь → 31
print(get_days(2))  # Февраль → 28
print(get_days(9))  # Сентябрь → 30
